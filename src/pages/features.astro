---
// src/pages/features.astro
import Layout from '../layouts/Layout.astro';

// PLACEHOLDER content -- copy and images are temporary, just blocking out
// the new layout: 3 alternating image+text rows (same style the page used
// previously for "bigFeatures"), then 1 big main-feature banner, repeated
// twice.
const ROMAN = ['I', 'II', 'III'];

const featureGroups = [
  {
    chapter: 'Chapter One',
    side: [
      { title: 'Side Feature A', text: 'Placeholder text for a smaller supporting feature, in the same alternating image+text row layout the page used before.', image: '/images/phases/dawn-breaks.webp' },
      { title: 'Side Feature B', text: 'Placeholder text for a smaller supporting feature.', image: '/images/phases/discuss-deduce.webp' },
      { title: 'Side Feature C', text: 'Placeholder text for a smaller supporting feature.', image: '/images/phases/the-vote.webp' },
    ],
    main: {
      title: 'Main Feature One',
      text: 'Placeholder copy for the first big feature banner. This is the large showcase that anchors the group, sitting below its three smaller supporting features.',
      image: '/images/phases/night-falls.webp',
    },
  },
  {
    chapter: 'Chapter Two',
    side: [
      { title: 'Side Feature D', text: 'Placeholder text for a smaller supporting feature.', image: '/images/phases/night-falls.webp' },
      { title: 'Side Feature E', text: 'Placeholder text for a smaller supporting feature.', image: '/images/phases/dawn-breaks.webp' },
      { title: 'Side Feature F', text: 'Placeholder text for a smaller supporting feature.', image: '/images/phases/discuss-deduce.webp' },
    ],
    main: {
      title: 'Main Feature Two',
      text: 'Placeholder copy for the second big feature banner.',
      image: '/images/phases/the-vote.webp',
    },
  },
];
---

<Layout title="Features" description="300+ roles, proximity voice chat, a personal notebook, deep customization, and community-hosted games — everything Werewolves Revenge has to offer.">
  <header class="bg-zinc-950 pt-28 pb-12 px-6 border-b border-[#97774A]/30 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(151,119,74,0.08),_transparent_60%)] z-0"></div>
    <div class="max-w-4xl mx-auto relative z-10 text-center">
      <div class="ornate-divider mb-6 justify-center">
        <span></span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.5 7.5L22 12l-7.5 2.5L12 22l-2.5-7.5L2 12l7.5-2.5z"/></svg>
        <span></span>
      </div>
      <h1 class="text-5xl md:text-7xl font-black text-white uppercase tracking-tighter mb-4 drop-shadow-lg" style="font-family: 'Beaufort', serif;">
        Features
      </h1>
      <p class="text-zinc-400 text-lg max-w-xl mx-auto">Every page of the tome that tells you why the village fears the dark.</p>
    </div>
  </header>

  <main id="main-content" class="bg-zinc-950 min-h-screen py-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(151,119,74,0.05),_transparent_70%)] z-0 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-6 space-y-28 relative z-10">
      {featureGroups.map((group, groupIndex) => (
        <div class="space-y-20">

          <div class="text-center">
            <span class="chapter-label">{group.chapter}</span>
          </div>

          {group.side.map((feature, i) => (
            <section class="grid md:grid-cols-2 gap-12 items-center">
              <div class={`relative ${i % 2 === 1 ? 'md:order-2' : ''}`}>
                <span class="feature-roman" style="font-family: 'Beaufort', serif;">{ROMAN[i]}</span>
                <h2 class="relative text-3xl md:text-4xl font-black text-white uppercase tracking-tight mb-6" style="font-family: 'Beaufort', serif;">{feature.title}</h2>
                <p class="relative text-lg text-zinc-400 leading-relaxed">
                  <span class="drop-cap">{feature.text.charAt(0)}</span>{feature.text.slice(1)}
                </p>
              </div>
              <div class={`relative ${i % 2 === 1 ? 'md:order-1' : ''}`}>
                <div class="absolute -inset-3 bg-gradient-to-br from-[#97774A]/15 via-transparent to-red-700/10 blur-2xl rounded-full"></div>
                <div class="feature-frame relative aspect-video rounded-sm overflow-hidden border border-[#97774A]/40 shadow-2xl">
                  <img src={feature.image} alt={feature.title} class="w-full h-full object-cover" loading="lazy" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
                  <span class="frame-corner frame-corner-tl"></span>
                  <span class="frame-corner frame-corner-tr"></span>
                  <span class="frame-corner frame-corner-bl"></span>
                  <span class="frame-corner frame-corner-br"></span>
                </div>
              </div>
            </section>
          ))}

          <div class="ornate-divider justify-center">
            <span></span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.5 7.5L22 12l-7.5 2.5L12 22l-2.5-7.5L2 12l7.5-2.5z"/></svg>
            <span></span>
          </div>

          <div class="relative">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-20">
              <span class="main-feature-ribbon">★ Main Feature ★</span>
            </div>
            <div class="relative rounded-sm overflow-hidden border-2 border-[#97774A]/60 shadow-[0_0_60px_-10px_rgba(151,119,74,0.4)]">
              <img src={group.main.image} alt={group.main.title} class="w-full aspect-[16/9] object-cover" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
              <div class="absolute inset-0 vignette-frame"></div>
              <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-10">
                <h2 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tight mb-3 drop-shadow-lg" style="font-family: 'Beaufort', serif;">{group.main.title}</h2>
                <p class="text-lg text-zinc-200 leading-relaxed drop-shadow-lg max-w-2xl">{group.main.text}</p>
              </div>
              <span class="frame-corner frame-corner-tl"></span>
              <span class="frame-corner frame-corner-tr"></span>
              <span class="frame-corner frame-corner-bl"></span>
              <span class="frame-corner frame-corner-br"></span>
            </div>
          </div>

        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  .chapter-label {
    display: inline-block;
    font-family: 'Beaufort', serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #97774A;
    border-top: 1px solid rgba(151, 119, 74, 0.4);
    border-bottom: 1px solid rgba(151, 119, 74, 0.4);
    padding: 0.4rem 1.5rem;
  }

  .feature-roman {
    position: absolute;
    top: -2.5rem;
    left: -0.5rem;
    font-size: 6rem;
    font-weight: 900;
    line-height: 1;
    color: rgba(151, 119, 74, 0.12);
    pointer-events: none;
    z-index: 0;
  }

  .feature-frame {
    position: relative;
  }

  .frame-corner {
    position: absolute;
    width: 1.75rem;
    height: 1.75rem;
    border-color: #97774A;
    z-index: 10;
  }

  .frame-corner-tl {
    top: 0.5rem;
    left: 0.5rem;
    border-top: 2px solid;
    border-left: 2px solid;
  }

  .frame-corner-tr {
    top: 0.5rem;
    right: 0.5rem;
    border-top: 2px solid;
    border-right: 2px solid;
  }

  .frame-corner-bl {
    bottom: 0.5rem;
    left: 0.5rem;
    border-bottom: 2px solid;
    border-left: 2px solid;
  }

  .frame-corner-br {
    bottom: 0.5rem;
    right: 0.5rem;
    border-bottom: 2px solid;
    border-right: 2px solid;
  }

  .main-feature-ribbon {
    display: inline-block;
    background: linear-gradient(to bottom, #b91c1c, #7f1d1d);
    color: #fff;
    font-family: 'Beaufort', serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.5rem 1.5rem;
    border: 1px solid rgba(151, 119, 74, 0.6);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
    white-space: nowrap;
  }
</style>
