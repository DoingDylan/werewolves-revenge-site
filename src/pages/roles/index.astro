---
// src/pages/roles/index.astro
import Layout from '../../layouts/Layout.astro';
import rolesData from '../../data/roles.json';
import factionsData from '../../data/factions.json';
import classesData from '../../data/classes.json';

const factionsById = Object.fromEntries(factionsData.map((f) => [f.id, f]));
const classesById = Object.fromEntries(classesData.map((c) => [c.id, c]));

// "setOrder" comes from export_roles.py's hand-ordered `allowed_sets` list,
// denormalized onto every role since there's no separate sets.json. Faction
// order/color now live in factions.json (the authoritative source), so we
// read those directly via factionsById rather than keeping a redundant copy
// on each role.
const setOrders = Object.fromEntries(rolesData.map((role) => [role.set, role.setOrder ?? 0]));
const uniqueSets = [...new Set(rolesData.map(role => role.set))]
  .filter(set => set !== "All")
  .sort((a, b) => (setOrders[a] ?? 0) - (setOrders[b] ?? 0) || a.localeCompare(b));

// Classes are the same four across every set, so the class filter buttons
// never need to change -- only their active/inactive state does.
const CLASS_ORDER = ['Elimination', 'Protection', 'Investigation', 'Manipulation'];
const uniqueClasses = CLASS_ORDER.filter((cls) => rolesData.some((role) => role.class === cls));

// Factions differ per set (e.g. Standard has Town/Werewolf, Dark has
// Village/Vampire), so build a per-set faction list the client script can
// swap in whenever the Set dropdown changes.
const factionsBySet = Object.fromEntries(
  uniqueSets.map((set) => {
    const rolesInSet = rolesData.filter((role) => role.set === set);
    const factionsInSet = [...new Set(rolesInSet.map((role) => role.faction))];
    const factionDisplayNames = Object.fromEntries(rolesInSet.map((role) => [role.faction, role.factionName]));
    return [
      set,
      factionsInSet
        .map((faction) => ({ id: faction, name: factionDisplayNames[faction] ?? faction, hex: factionsById[faction]?.color ?? '#71717a', iconUrl: factionsById[faction]?.iconUrl ?? null }))
        .sort((a, b) => (factionsById[a.id]?.order ?? 0) - (factionsById[b.id]?.order ?? 0) || a.name.localeCompare(b.name)),
    ];
  })
);

const DEFAULT_SET = uniqueSets.includes('Standard') ? 'Standard' : uniqueSets[0];
---

<Layout title="Roles" description="Browse every role in Werewolves Revenge — search and filter by set, faction, and class.">

  <main id="main-content" class="bg-zinc-950 min-h-screen pt-28 pb-16 px-4 md:px-8 relative z-20">
    <div class="max-w-[1400px] mx-auto">

      <div class="bg-zinc-900/50 border border-[#97774A]/30 rounded-sm p-6 md:p-8 backdrop-blur-sm flex flex-col gap-6 mb-12">
        <div class="flex flex-col md:flex-row items-stretch md:items-center justify-between gap-4">
          <h1 class="text-6xl -my-5 leading-none font-black text-white uppercase tracking-tighter drop-shadow-lg" style="font-family: 'Beaufort', serif;">
            Roles
          </h1>

          <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
            <div class="flex items-center gap-3">
              <p class="text-[#97774A] text-xs font-bold uppercase tracking-widest whitespace-nowrap">Set</p>
              <select
                id="setFilter"
                class="bg-zinc-950 border border-[#97774A]/40 text-white px-4 py-3 rounded-md focus:outline-none focus:border-red-500 transition-colors cursor-pointer appearance-none uppercase font-bold text-sm tracking-wider"
              >
                {uniqueSets.map(set => (
                  <option value={set} selected={set === DEFAULT_SET}>{set}</option>
                ))}
              </select>
            </div>

            <div class="relative">
              <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-500 pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="7"/>
                <path d="M21 21l-4.35-4.35"/>
              </svg>
              <input
                type="text"
                id="searchInput"
                placeholder="Search roles..."
                class="w-full sm:w-72 bg-zinc-950 border border-[#97774A]/40 text-white pl-11 pr-6 py-3 rounded-md focus:outline-none focus:border-red-500 transition-colors placeholder-zinc-600"
              />
            </div>
          </div>
        </div>

        <div class="flex flex-col xl:flex-row gap-6 pt-6 border-t border-[#97774A]/20">
          <div class="flex-1 min-w-0">
            <p class="text-[#97774A] text-xs font-bold uppercase tracking-widest mb-3">Faction</p>
            <div id="factionFilterGroup" class="filter-scroll flex flex-nowrap gap-2 overflow-x-auto" data-active=""></div>
          </div>

          <div class="flex-1 min-w-0">
            <p class="text-[#97774A] text-xs font-bold uppercase tracking-widest mb-3">Class</p>
            <div id="classFilterGroup" class="filter-scroll flex flex-nowrap gap-2 overflow-x-auto" data-active="">
              {uniqueClasses.map((cls) => (
                <button type="button" class="filter-btn" data-value={cls} style={`--btn-color: ${classesById[cls]?.color ?? '#71717a'}; --btn-icon: url('${classesById[cls]?.iconUrl ?? ''}')`}>
                  {classesById[cls]?.iconUrl && <span class="filter-btn-icon"></span>}
                  {cls}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>

      <p id="noResults" class="hidden text-center text-zinc-500 py-16 text-lg">
        No roles match your search.
      </p>

      <div class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-9 lg:grid-cols-11 gap-3 md:gap-4" id="rolesGrid">

        {rolesData.map((role) => {
          const factionHex = factionsById[role.faction]?.color ?? '#71717a';

          return (
            <a
              href={`/roles/${role.set.toLowerCase()}/${role.id}`}
              class="role-card faction-card group relative block aspect-square bg-zinc-900 rounded border border-zinc-800 overflow-hidden transition-transform duration-300 hover:scale-150 hover:z-30"
              style={`--faction: ${factionHex}; ${role.set === DEFAULT_SET ? '' : 'display: none;'}`}
              data-set={role.set}
              data-name={role.name.toLowerCase()}
              data-faction={role.faction}
              data-class={role.class}
              aria-label={role.name}
            >
              <img
                src={role.portraitUrl || '/images/roles/default_portrait.webp'}
                alt={role.name}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </a>
          );
        })}

      </div>
    </div>
  </main>
</Layout>

<style is:global>
  .filter-scroll {
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .filter-scroll::-webkit-scrollbar {
    display: none;
  }

  .filter-btn {
    --btn-color: #71717a;
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    white-space: nowrap;
    gap: 0.4rem;
    padding: 0.5rem 0.7rem;
    border-radius: 0.375rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(39, 39, 42, 0.6);
    color: #d4d4d8;
    font-weight: 700;
    font-size: calc(0.8rem + 1pt);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .filter-btn-icon {
    display: inline-block;
    width: 1em;
    height: 1em;
    flex-shrink: 0;
    margin-right: 0.45em;
    background-color: var(--btn-color);
    -webkit-mask: var(--btn-icon) no-repeat center / contain;
    mask: var(--btn-icon) no-repeat center / contain;
    transition: background-color 0.15s ease;
    /* Visually double the icon without affecting layout (button stays the
       same size) -- transform doesn't trigger reflow, it's paint-only. */
    transform: scale(2);
  }

  .filter-btn:hover {
    border-color: var(--btn-color);
    color: #ffffff;
  }

  .filter-btn:hover .filter-btn-icon {
    background-color: #ffffff;
  }

  .filter-btn.active {
    background: color-mix(in srgb, var(--btn-color) 25%, transparent);
    border-color: var(--btn-color);
    color: #ffffff;
    box-shadow: 0 0 12px -2px var(--btn-color);
  }

  .filter-btn.active .filter-btn-icon {
    background-color: #ffffff;
  }
</style>

<script define:vars={{ factionsBySet, DEFAULT_SET }}>
  document.addEventListener('DOMContentLoaded', () => {
    const roleCards = document.querySelectorAll('.role-card');
    const setFilter = document.getElementById('setFilter');
    const factionGroup = document.getElementById('factionFilterGroup');
    const classGroup = document.getElementById('classFilterGroup');
    const searchInput = document.getElementById('searchInput');
    const noResults = document.getElementById('noResults');

    if (!setFilter || !factionGroup || !classGroup || !searchInput || !noResults) return;

    function renderFactionButtons(set) {
      const factions = factionsBySet[set] || [];
      factionGroup.innerHTML = '';

      factions.forEach((faction) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'filter-btn';
        btn.dataset.value = faction.id;
        btn.style.setProperty('--btn-color', faction.hex);

        if (faction.iconUrl) {
          btn.style.setProperty('--btn-icon', `url('${faction.iconUrl}')`);
          const icon = document.createElement('span');
          icon.className = 'filter-btn-icon';
          btn.appendChild(icon);
        }

        btn.appendChild(document.createTextNode(faction.name));
        factionGroup.appendChild(btn);
      });
    }

    // No active buttons in a group means "no filter" -- i.e. show every
    // value -- rather than there being a dedicated "All" button to select.
    function getActiveValues(group) {
      return Array.from(group.querySelectorAll('.filter-btn.active')).map((b) => b.dataset.value);
    }

    function filterRoles() {
      const selectedSet = setFilter.value;
      const selectedFactions = getActiveValues(factionGroup);
      const selectedClasses = getActiveValues(classGroup);
      const searchTerm = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      roleCards.forEach((card) => {
        const roleName = card.dataset.name ?? '';
        const matchesSet = card.dataset.set === selectedSet;
        const matchesFaction = selectedFactions.length === 0 || selectedFactions.includes(card.dataset.faction);
        const matchesClass = selectedClasses.length === 0 || selectedClasses.includes(card.dataset.class);
        const matchesSearch = roleName.includes(searchTerm);
        const isVisible = matchesSet && matchesFaction && matchesClass && matchesSearch;

        card.style.display = isVisible ? 'block' : 'none';
        if (isVisible) visibleCount++;
      });

      noResults.classList.toggle('hidden', visibleCount > 0);
    }

    // Only one button per group can be active at a time -- clicking the
    // already-active one deselects it (back to "no filter" / show all).
    function selectSingleButton(group, btn) {
      const wasActive = btn.classList.contains('active');
      group.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
      if (!wasActive) btn.classList.add('active');
    }

    factionGroup.addEventListener('click', (e) => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;
      selectSingleButton(factionGroup, btn);
      filterRoles();
    });

    classGroup.addEventListener('click', (e) => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;
      selectSingleButton(classGroup, btn);
      filterRoles();
    });

    setFilter.addEventListener('change', () => {
      renderFactionButtons(setFilter.value);
      filterRoles();
    });

    searchInput.addEventListener('input', filterRoles);

    // Initial render so "Standard" (or whichever default set) shows
    // immediately with the right faction buttons.
    renderFactionButtons(DEFAULT_SET);
    filterRoles();
  });
</script>
