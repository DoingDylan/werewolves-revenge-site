---
// src/pages/how-to-play.astro
import Layout from '../layouts/Layout.astro';

const phases = [
  { n: 'I', title: 'Night Falls', text: 'Werewolves and other secret factions meet in secret to plot, scheme, and choose a victim. Most night abilities are used during this phase — protections, investigations, and attacks all happen here, hidden from the rest of the village.' },
  { n: 'II', title: 'Dawn Breaks', text: "The Town wakes to discover the night's events. Bodies are found, clues surface, and suspicion spreads. This is the moment to take stock of what happened and start forming theories." },
  { n: 'III', title: 'Discuss & Deduce', text: 'Use Proximity Voice Chat to discuss openly or plot in private, but beware of enemies listening in from the shadows. This is the heart of the game — share information, build alliances, and try to spot the lies.' },
  { n: 'IV', title: 'The Town Votes', text: 'The Town votes on who to interrogate, then who to execute before the day ends. Choose wisely — the wrong vote could remove an ally and leave the village more vulnerable than before.' },
];

const tips = [
  { title: 'Pay attention to claims', text: 'Every player who speaks up is making a claim about who they are or what they saw. Keep track of contradictions.' },
  { title: 'Use your Notebook', text: 'Track suspicions, claims, and votes as the game goes on — memory alone won’t cut it once accusations start flying.' },
  { title: "Don't reveal too early", text: 'Information is power. Revealing your role or what you know too soon can make you a target.' },
  { title: 'Listen for proximity slip-ups', text: 'Proximity voice chat means nearby players might overhear more than they should — choose where you talk carefully.' },
];
---

<Layout title="How To Play" description="Learn the rules of Werewolves Revenge: the day/night cycle, voting, win conditions, and tips for your first game.">
  <header class="bg-zinc-950 pt-28 pb-12 px-6 border-b border-[#97774A]/30 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(151,119,74,0.08),_transparent_60%)] z-0"></div>
    <div class="max-w-4xl mx-auto relative z-10 text-center">
      <div class="ornate-divider mb-6 justify-center">
        <span></span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.5 7.5L22 12l-7.5 2.5L12 22l-2.5-7.5L2 12l7.5-2.5z"/></svg>
        <span></span>
      </div>
      <h1 class="text-5xl md:text-6xl font-black text-white uppercase tracking-tighter mb-4 drop-shadow-lg" style="font-family: 'Beaufort', serif;">
        How To Play
      </h1>
      <p class="text-zinc-500 max-w-xl mx-auto">Everything you need to know before your first night in the village.</p>
    </div>
  </header>

  <main id="main-content" class="bg-zinc-950 min-h-screen">

    <!-- OVERVIEW -->
    <section class="max-w-4xl mx-auto px-6 py-12 md:py-20">
      <h2 class="text-2xl font-bold text-white mb-4" style="font-family: 'Beaufort', serif;">The Basics</h2>
      <p class="text-lg text-zinc-400 leading-relaxed mb-4">
        Werewolves Revenge is a social deduction game for 8–16 players. Every player is secretly assigned a role belonging to one of several factions — Town, Werewolves, Neutral, Evil, and Lesser Evil — each with its own goals and win condition.
      </p>
      <p class="text-lg text-zinc-400 leading-relaxed">
        The game alternates between Night and Day. At night, secret factions and special roles act in private. By day, everyone discusses, debates, and ultimately votes on who to trust — and who to execute.
      </p>
    </section>

    <!-- PHASES -->
    <section class="bg-[#0c0a08] border-y border-[#97774A]/30 py-12 md:py-20">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-white mb-10 text-center" style="font-family: 'Beaufort', serif;">The Day/Night Cycle</h2>
        <div class="space-y-6">
          {phases.map((phase) => (
            <div class="flex gap-6 bg-zinc-900/50 border border-[#97774A]/30 rounded-sm p-6">
              <span class="text-4xl font-black text-[#97774A]/60 shrink-0" style="font-family: 'Beaufort', serif;">{phase.n}</span>
              <div>
                <h3 class="text-xl font-bold text-white mb-2" style="font-family: 'Beaufort', serif;">{phase.title}</h3>
                <p class="text-zinc-400 leading-relaxed">{phase.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WIN CONDITIONS -->
    <section class="max-w-4xl mx-auto px-6 py-12 md:py-20">
      <h2 class="text-2xl font-bold text-white mb-4" style="font-family: 'Beaufort', serif;">Winning The Game</h2>
      <p class="text-lg text-zinc-400 leading-relaxed mb-6">
        Each faction has its own win condition — the Town wants every threat eliminated, the Werewolves want to overpower the village, and Neutral and Evil roles often have their own unique objectives entirely. A full breakdown of every faction's win condition is on the <a href="/#tale" class="text-red-500 hover:text-red-400 underline">home page</a>, and every individual role — including its full ability list — is catalogued in the <a href="/roles" class="text-red-500 hover:text-red-400 underline">Role Directory</a>.
      </p>
    </section>

    <!-- TIPS -->
    <section class="bg-[#0c0a08] border-y border-[#97774A]/30 py-12 md:py-20">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-white mb-10 text-center" style="font-family: 'Beaufort', serif;">Tips For New Players</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {tips.map((tip) => (
            <div class="bg-zinc-900/50 border border-[#97774A]/30 rounded-sm p-6">
              <h3 class="text-lg font-bold text-white mb-2" style="font-family: 'Beaufort', serif;">{tip.title}</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">{tip.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- KEYWORDS CALLOUT -->
    <section class="max-w-4xl mx-auto px-6 py-20 text-center">
      <h2 class="text-2xl font-bold text-white mb-4" style="font-family: 'Beaufort', serif;">Confused by a keyword?</h2>
      <p class="text-zinc-400 mb-6">Role and ability descriptions use a handful of recurring keywords like Protect, Reveal, and Execute. Look them up any time in the glossary.</p>
      <a href="/keywords" class="inline-flex items-center justify-center px-8 py-4 font-bold text-white uppercase tracking-[0.2em] text-sm border border-[#97774A]/40 rounded-sm hover:border-[#97774A]/60 transition-colors">
        Browse The Keyword Glossary
      </a>
    </section>

  </main>
</Layout>
